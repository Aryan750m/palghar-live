# Apache configuration for Palghar LIVE
# Enables clean URLs and proper PHP routing

Options -Indexes
Options +FollowSymLinks

# Enable rewrite engine
RewriteEngine On

# Redirect to index.php if file/directory not found
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security: Block access to sensitive files
<FilesMatch "\.(env|lock|sql|log|md|yaml|json|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP settings (Shared hosting overrides)
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 60
php_value memory_limit 256M

# Charset
AddDefaultCharset UTF-8
