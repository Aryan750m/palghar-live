# Apache configuration for Palghar LIVE
# Enables clean URLs, security, caching, and performance

Options -Indexes
Options +FollowSymLinks

# Enable rewrite engine
RewriteEngine On

# ─── Favicon Redirect ───────────────────────────────────────────────────────
# Serve our logo JPEG as the favicon.ico
RewriteRule ^favicon\.ico$ assets/images/WhatsApp%20Image%202026-06-29%20at%202.29.31%20PM.jpeg [L,T=image/jpeg]

# ─── Clean URL Rewrites ──────────────────────────────────────────────────────
# /news/123/article-slug -> news-detail.php?id=123
RewriteRule ^news/([0-9]+)/?(.*)$ news-detail.php?id=$1 [QSA,L]

# /category/section-id -> index.php?cat=section-id
RewriteRule ^category/([a-zA-Z0-9_-]+)/?$ index.php?cat=$1 [QSA,L]

# /sitemap.xml -> sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# /feed.xml or /rss -> feed.php
RewriteRule ^(feed\.xml|rss)$ feed.php [L]

# Default fallback: send unknown paths to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ─── Security Headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ─── Block Sensitive Files ───────────────────────────────────────────────────
<FilesMatch "\.(env|lock|sql|log|gitignore|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to app/ and logs/ directories directly
RewriteRule ^(app|logs)/(.*)$ - [F,L]

# ─── Asset Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg          "access plus 1 month"
    ExpiresByType image/png           "access plus 1 month"
    ExpiresByType image/webp          "access plus 1 month"
    ExpiresByType image/avif          "access plus 1 month"
    ExpiresByType image/svg+xml       "access plus 1 month"
    ExpiresByType image/gif           "access plus 1 month"
    ExpiresByType text/css            "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/json    "access plus 1 day"
    ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

# ─── Gzip Compression ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>

# ─── PHP Settings (Shared Hosting Overrides) ─────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 256M
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>

# Charset
AddDefaultCharset UTF-8
